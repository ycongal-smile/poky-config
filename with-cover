#!/usr/bin/env python3
"""with-cover - wrapper around create-pull-request that auto-fills the Yocto LTS
cover-letter body, then re-adds the "*** BLURB HERE ***" send guard.

Prepend it to the exact create-pull-request command line from an
LTS-*-process.txt file, e.g.

  ../poky-config/with-cover scripts/create-pull-request -u contrib \\
      -p "OE-core][scarthgap" -s "Patch review" \\
      -b stable/scarthgap-nut -r stable/scarthgap-next

What it does:
  * Reads the mode from the -s subject: "Patch review" -> review,
    "Pull request" -> merge.
  * Fills the release codename (from $LTS_RELEASE, else detected in -p / -b)
    and, for reviews, the "comments back by" deadline (today + 2 working days,
    Mon-Fri, holidays ignored).
  * Leaves every field it cannot know (autobuilder URL, previous-review link)
    as XXX.
  * Passes the generated body to create-pull-request via -m, runs it, then
    re-inserts "*** BLURB HERE ***" at the top of the generated cover-letter
    body. create-pull-request strips that token from -m input, so it is added
    afterwards; send-pull-request then refuses to send until you edit it out.
  * For a merge ("Pull request (cover letter only)"), removes every generated
    *.patch except the cover letter, so send-pull-request e-mails only the
    cover letter.

It stays out of the way (runs the command unchanged) when:
  * the subject is neither a review nor a pull request, or
  * you already passed -m (your body wins).

The upstream create-pull-request script is never modified.
"""

import datetime
import glob
import os
import subprocess
import sys
import tempfile

RELEASES = ("kirkstone", "scarthgap", "walnascar", "whinlatter", "wrynose")

WEEKDAYS = ("Monday", "Tuesday", "Wednesday", "Thursday", "Friday",
            "Saturday", "Sunday")
MONTHS = ("January", "February", "March", "April", "May", "June", "July",
          "August", "September", "October", "November", "December")

BLURB = "*** BLURB HERE ***"
REVIEW_ANCHOR = "Please review this set of changes for"
MERGE_ANCHOR = "Those are the patches from the last patch review:"


def opt_value(args, i):
    """Return (value, next_index) for an option at args[i].

    Supports both the separate form ("-s value") and the glued form
    ("-svalue"), matching how getopts in create-pull-request accepts them.
    """
    a = args[i]
    if len(a) > 2:
        return a[2:], i + 1
    if i + 1 < len(args):
        return args[i + 1], i + 2
    return "", i + 1


def scan_args(args):
    """Read -s / -p / -b values and whether -m is already present. Read-only."""
    subject = prefix = branch = ""
    has_body = False
    i = 0
    while i < len(args):
        a = args[i]
        if a.startswith("-s"):
            subject, i = opt_value(args, i)
            continue
        if a.startswith("-p"):
            prefix, i = opt_value(args, i)
            continue
        if a.startswith("-b"):
            branch, i = opt_value(args, i)
            continue
        if a.startswith("-m"):
            has_body = True
        i += 1
    return subject, prefix, branch, has_body


def detect_mode(subject):
    if "Patch review" in subject:
        return "review"
    if "Pull request" in subject:
        return "merge"
    return None


def detect_release(prefix, branch):
    env = os.environ.get("LTS_RELEASE", "").strip()
    if env:
        return env
    haystack = "%s %s" % (prefix, branch)
    for release in RELEASES:
        if release in haystack:
            return release
    return "XXX"


def deadline_str(today=None):
    """Send day + 2 working days (Mon-Fri); holidays are not accounted for."""
    day = today or datetime.date.today()
    added = 0
    while added < 2:
        day += datetime.timedelta(days=1)
        if day.weekday() < 5:  # Mon..Fri == 0..4
            added += 1
    return "%s, %s %d" % (WEEKDAYS[day.weekday()], MONTHS[day.month - 1], day.day)


def review_body(release, deadline):
    return (
        "Please review this set of changes for %s and have comments back by\n"
        "end of day %s.\n"
        "\n"
        "Passed a-full on autobuilder:\n"
        "XXX\n"
        "\n"
    ) % (release, deadline)


def merge_body():
    return (
        "Those are the patches from the last patch review:\n"
        "XXX\n"
        "\n"
        "Passed a-full on autobuilder:\n"
        "XXX\n"
        "\n"
    )


def find_cover_letter(stdout):
    """Parse create-pull-request's report for the cover-letter path."""
    if not stdout:
        return None
    lines = stdout.splitlines()
    for i, line in enumerate(lines):
        if "especially the summary mail:" in line:
            for cand in lines[i + 1:]:
                cand = cand.strip()
                if cand.endswith("cover-letter.patch"):
                    return cand
    for line in lines:  # fallback: any cover-letter path it mentioned
        cand = line.strip()
        if cand.endswith("cover-letter.patch"):
            return cand
    return None


def insert_blurb(path, anchor):
    """Insert '*** BLURB HERE ***' + blank line before the first anchor line."""
    try:
        with open(path, "r") as handle:
            lines = handle.readlines()
    except OSError as err:
        sys.stderr.write("with-cover: WARNING: cannot read %s: %s; "
                         "'%s' NOT added.\n" % (path, err, BLURB))
        return
    out = []
    inserted = False
    for line in lines:
        if not inserted and line.startswith(anchor):
            out.append(BLURB + "\n")
            out.append("\n")
            inserted = True
        out.append(line)
    if not inserted:
        sys.stderr.write("with-cover: WARNING: body anchor not found in %s; "
                         "'%s' NOT added.\n" % (path, BLURB))
        return
    with open(path, "w") as handle:
        handle.writelines(out)
    sys.stderr.write("with-cover: added '%s' to %s\n" % (BLURB, path))


def remove_non_cover_patches(cover):
    """Delete every *.patch in the cover letter's dir except the cover itself.

    A "Pull request (cover letter only)" e-mails just the cover letter, so the
    numbered patches create-pull-request also generated must be removed before
    send-pull-request (which sends $PDIR/*.patch).
    """
    pull_dir = os.path.dirname(cover) or "."
    keep = os.path.basename(cover)
    removed = []
    for path in sorted(glob.glob(os.path.join(pull_dir, "*.patch"))):
        if os.path.basename(path) == keep:
            continue
        try:
            os.remove(path)
            removed.append(os.path.basename(path))
        except OSError as err:
            sys.stderr.write("with-cover: WARNING: could not remove %s: %s\n"
                             % (path, err))
    if removed:
        sys.stderr.write("with-cover: cover-letter-only pull request: removed "
                         "%d patch file(s) from %s:\n" % (len(removed), pull_dir))
        for name in removed:
            sys.stderr.write("with-cover:   - %s\n" % name)
    return removed


def main(argv):
    if not argv:
        sys.stderr.write("usage: with-cover <create-pull-request> [args...]\n")
        return 2

    cmd, rest = argv[0], argv[1:]
    subject, prefix, branch, has_body = scan_args(rest)
    mode = detect_mode(subject)

    # Inert passthrough: not a review/merge, or the user supplied their own body.
    if mode is None or has_body:
        return subprocess.run([cmd, *rest]).returncode

    release = detect_release(prefix, branch)
    if mode == "review":
        deadline = deadline_str()
        body, anchor = review_body(release, deadline), REVIEW_ANCHOR
        sys.stderr.write("with-cover: mode=review release=%s deadline=%r\n"
                         % (release, deadline))
    else:
        body, anchor = merge_body(), MERGE_ANCHOR
        sys.stderr.write("with-cover: mode=merge release=%s\n" % release)

    sys.stderr.write("with-cover: generated cover-letter body:\n")
    for line in body.splitlines():
        sys.stderr.write("with-cover:   | %s\n" % line)

    tmp = tempfile.NamedTemporaryFile("w", prefix="with-cover.", suffix=".txt",
                                      delete=False)
    try:
        tmp.write(body)
        tmp.close()
        proc = subprocess.run([cmd, "-m", tmp.name, *rest],
                              text=True, stdout=subprocess.PIPE)
        if proc.stdout:
            sys.stdout.write(proc.stdout)
        if proc.returncode != 0:
            return proc.returncode
        cover = find_cover_letter(proc.stdout)
        if cover:
            insert_blurb(cover, anchor)
            if mode == "merge":
                remove_non_cover_patches(cover)
        else:
            sys.stderr.write("with-cover: WARNING: could not locate the cover "
                             "letter; '%s' NOT added" % BLURB)
            if mode == "merge":
                sys.stderr.write(" and non-cover patches NOT removed")
            sys.stderr.write(".\n")
        return 0
    finally:
        os.unlink(tmp.name)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
